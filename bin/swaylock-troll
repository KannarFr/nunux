#!/bin/sh
# Fired by pam_exec from /etc/pam.d/swaylock on a WRONG unlock attempt.
# Pops a big swaync notification *over* the lock screen — swaync lives on the
# overlay layer (same as swaylock) and is created on demand, so it draws on top.
#
# swaylock is not setuid, so PAM auth runs as the logged-in user and pam_exec
# inherits that uid. PAM hands us a near-empty environment, though, so point
# notify-send at the session bus ourselves (libdbus reads $XDG_RUNTIME_DIR/bus).
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=$XDG_RUNTIME_DIR/bus}"

# x-canonical-private-synchronous makes repeated wrong tries replace the popup
# in place instead of stacking (same trick as bin/osd).
notify-send -t 5000 \
	-h string:x-canonical-private-synchronous:goat \
	"🐐  NICE TRY  🐐" \
	"<span size='30720' weight='bold'>did you really try to hack
the goat kannar?</span>"

exit 0
