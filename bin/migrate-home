#!/usr/bin/env bash
#
# migrate-home — pull /home/$USER from the old laptop onto this (new) one.
#
# Run this ON THE NEW laptop, after the base Arch install + first boot, as your
# user but from a plain TTY — NOT inside the sway/graphical session. Copying over
# a live desktop's open dotfiles, sockets and lock files is asking for trouble.
#
# It rsyncs the whole home over SSH, preserving owners, perms, ACLs, xattrs,
# symlinks and hardlinks. Because it brings ~/.ssh, ~/.gnupg,
# ~/.local/share/secrets.env, the coursier cache and the nunux checkout (with
# its symlinks intact), it also covers most of bootstrap.sh's manual checklist.
#
# Prereqs: same username on both boxes, matching UID/GID (1000), and sshd
# reachable on the old laptop (it's enabled in this config).
#
#   ./migrate-home OLD_HOST             pull /home/$USER from OLD_HOST
#   ./migrate-home user@OLD_HOST        ... as a specific remote user
#   ./migrate-home --dry-run OLD_HOST   show what would transfer, change nothing
#   ./migrate-home --slim OLD_HOST      skip regenerable caches (smaller/faster)
#
# Order: encrypt + base-install the new box first, then this, then ./bootstrap.sh.
#
set -euo pipefail

warn() { printf '\033[1;33m  ! %s\033[0m\n' "$*"; }

DRY=() SLIM=0
while [ $# -gt 0 ]; do
  case "$1" in
    --dry-run|-n) DRY=(--dry-run); shift ;;
    --slim)       SLIM=1; shift ;;
    -*) printf 'usage: %s [--dry-run] [--slim] [user@]old-host\n' "${0##*/}" >&2; exit 2 ;;
    *)  break ;;
  esac
done

[ $# -ge 1 ] || { printf 'usage: %s [--dry-run] [--slim] [user@]old-host\n' "${0##*/}" >&2; exit 2; }
SRC_HOST="$1"
case "$SRC_HOST" in *@*) ;; *) SRC_HOST="$USER@$SRC_HOST" ;; esac

command -v rsync >/dev/null || { echo "rsync not installed (pacman -S rsync)" >&2; exit 1; }
[ "$(id -u)" -ne 0 ] || { echo "run as your user, not root (keeps ownership + uses your ssh keys)" >&2; exit 1; }

# Paths assume the same username/home on both boxes. Trailing slash on SRC means
# "copy the contents of remote $HOME into local $HOME", not a nested dir.
SRC="${SRC_HOST}:${HOME}/"
DEST="$HOME/"

# Always skip: filesystem cruft and things that can't be recreated as files.
EXCLUDES=(
  --exclude 'lost+found'
  --exclude '.gvfs/'
  --exclude '.dbus/'
  --exclude '.local/share/gvfs-metadata/'
)
# --slim additionally drops regenerable bulk. NOTE: this includes ~/.cache, which
# holds the coursier JDK referenced by zprofile — if you slim, re-run `cs setup`.
if [ "$SLIM" -eq 1 ]; then
  EXCLUDES+=(
    --exclude '.cache/'
    --exclude '.local/share/Trash/'
    --exclude '.thumbnails/'
    --exclude '*/node_modules/'
    --exclude '.mozilla/firefox/*/cache2/'
  )
fi

printf 'Local:  %s (%s:%s)  ->  %s\n' "$USER" "$(id -u)" "$(id -g)" "$DEST"
printf 'Remote: %s\n' "$SRC"
[ "$(id -u)" -eq 1000 ] || warn "local UID is $(id -u), not 1000 — ownership may not match the old box"
echo

# -a archive, -H hardlinks, -A ACLs, -X xattrs; numeric ids so ownership is
# copied verbatim instead of remapped by name.
set +e
rsync -aHAX --numeric-ids --info=progress2 --partial "${DRY[@]}" \
  "${EXCLUDES[@]}" "$SRC" "$DEST"
rc=$?
set -e

case "$rc" in
  0)  echo "Copy complete." ;;
  23) warn "rsync exit 23: some files weren't transferred (sockets / unreadable / perms) — usually harmless" ;;
  24) warn "rsync exit 24: some source files vanished mid-copy — usually harmless" ;;
  *)  echo "rsync failed (exit $rc)" >&2; exit "$rc" ;;
esac

cat <<'EOF'

Next:
  - ./bootstrap.sh   (packages + services; apply.sh will find your symlinks already in place)
  - Copy the /etc files by hand, REGENERATING fstab + crypttab for the new disk.
  - Re-login (or reboot) so the copied shell/session state takes effect.
EOF
