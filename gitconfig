[user]
	email = kannarfr@gmail.com
	name = kannar
	signingkey = 0548E2F14DDDFF40EB9D01DA2B81AD058BF050D8

[color]
    ui = auto

[diff]
    renames = copy
    renameLimit = 16536

[url "git+ssh://git@gitlab.corp.clever-cloud.com/clever-cloud/"]
	insteadOf = clever:

[url "git+ssh://git@github.com/"]
	insteadOf = github:

[commit]
	gpgsign = true

[gpg]
	program = gpg

[alias]
	co-pr = !sh -c 'git fetch origin pull/$1/head:pr/$1 && git checkout pr/$1' -
    fixup = "!git log -n 50 --pretty=format:'%h %s' --no-merges | fzf | cut -c -7 | xargs -o git commit --fixup"
	pfwl = push --force-with-lease
	p = push
	st = status -sb

[pull]
	rebase = true

[push]
    default = simple
	autoSetupRemote = true

[gitreview]
    username = KannarFR

[transfer]
    fsckobjects = true

[fetch]
    fsckobjects = true

[receive]
    fsckObjects = true

[log]
	mailmap = true

[help]
	autoCorrect = 3

[core]
	fileMode = true

[rebase]
	autosquash = true
[safe]
	directory = /usr/src/linux-stable
[commit]
	gpgsign = true
	gpgsign = true
[init]
	defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[credential "https://gitlab.corp.clever-cloud.com"]
	helper = 
	helper = !/usr/bin/glab auth git-credential
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
