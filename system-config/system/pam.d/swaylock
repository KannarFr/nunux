#%PAM-1.0
#
# swaylock screen locker. Wrapped so a WRONG password fires the troll script
# (a big "did you really try to hack the goat kannar?" swaync popup) before the
# auth is denied; a CORRECT password takes the success-jump and skips it.
#
#   [success=2 ...] on the login substack -> skip the next 2 modules
#   (pam_exec + pam_deny), landing on pam_permit = unlock succeeds.
#   On failure: fall through to pam_exec (popup) then pam_deny = stays locked.
#
auth      [success=2 default=ignore]  substack    login
auth      optional                    pam_exec.so seteuid quiet /home/kannar/git/kannar/nunux/bin/swaylock-troll
auth      requisite                   pam_deny.so
auth      optional                    pam_permit.so
