# ~/.config/swaylock/config — symlinked from the nunux dotfiles repo.
# Vanilla swaylock 1.8.5: no clock/blur support; informative indicator only.

ignore-empty-password
show-failed-attempts
indicator-caps-lock

font=JetBrainsMono Nerd Font
indicator-radius=110
indicator-thickness=10

# base (idle / typing)
color=11111b
inside-color=1e1e2e
ring-color=585b70
line-color=00000000
separator-color=00000000
text-color=cdd6f4
key-hl-color=89b4fa
bs-hl-color=f38ba8

# verifying
inside-ver-color=1e1e2e
ring-ver-color=89b4fa
line-ver-color=00000000
text-ver-color=89b4fa

# wrong password
inside-wrong-color=1e1e2e
ring-wrong-color=f38ba8
line-wrong-color=00000000
text-wrong-color=f38ba8

# cleared
inside-clear-color=1e1e2e
ring-clear-color=f9e2af
line-clear-color=00000000
text-clear-color=11111b

# caps lock active
inside-caps-lock-color=1e1e2e
ring-caps-lock-color=fab387
text-caps-lock-color=fab387
caps-lock-key-hl-color=fab387
